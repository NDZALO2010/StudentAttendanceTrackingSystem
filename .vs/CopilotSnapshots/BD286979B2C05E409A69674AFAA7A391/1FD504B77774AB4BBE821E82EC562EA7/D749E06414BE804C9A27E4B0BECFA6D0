{% load static %}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EduTrack Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    {% include "includes/theme_variables.html" %}
    <style>
        :root {
            --sidebar-bg: #34495e;
            --sidebar-text: #ecf0f1;
            --card-bg: #ffffff;
            --card-border: rgba(0,0,0,0.1);
            --link-active: #e74c3c;
            --btn-danger: #e74c3c;
            --btn-success: #27ae60;
            --btn-warning: #f39c12;
            --shadow: rgba(0,0,0,0.1);
        }
        .dark-theme {
            --sidebar-bg: #0f172a;
            --sidebar-text: #f1f5f9;
            --card-bg: #0b1220;
            --card-border: rgba(255,255,255,0.08);
            --link-active: #fb7185;
            --btn-danger: #f87171;
            --btn-success: #34d399;
            --btn-warning: #fbbf24;
            --shadow: rgba(0,0,0,0.5);
        }
        body {
            background-color: var(--bg) !important;
            color: var(--text) !important;
        }

        /* Ensure the admin pages use the custom theme even when Bootstrap adds bg-* classes */
        body.bg-light, body.bg-white, body.bg-dark {
            background-color: var(--bg) !important;
            color: var(--text) !important;
        }

        /* Force consistent text color in main content */
        .main-content,
        .main-content h1,
        .main-content h2,
        .main-content h3,
        .main-content h4,
        .main-content h5,
        .main-content h6,
        .main-content p,
        .main-content a,
        .main-content span,
        .main-content label {
            color: var(--text) !important;
        }
        .sidebar {
            width: 240px;
            min-height: 100vh;
            background-color: var(--sidebar-bg);
            color: var(--sidebar-text);
            position: fixed;
            padding: 20px;
            box-shadow: 2px 0 10px var(--shadow);
        }
        .sidebar .nav-link {
            color: var(--sidebar-text);
            padding: 10px 12px;
            border-radius: 6px;
        }
        .sidebar .nav-link.active, .sidebar .nav-link:hover {
            background-color: var(--link-active);
            color: white;
        }
        .main-content {
            margin-left: 260px;
            padding: 20px;
        }
        .card {
            background: var(--card-bg);
            border: 1px solid var(--card-border);
            border-radius: 10px;
            box-shadow: 0 1px 12px var(--shadow);
        }
        .table thead th {
            border-bottom: 2px solid var(--card-border);
        }
        .form-actions {
            margin-top: 1rem;
        }

        /* Top-right buttons (View Site + Logout) */
        .admin-top-right {
            position: fixed;
            top: 18px;
            right: 18px;
            z-index: 1050;
            display: flex;
            gap: 0.5rem;
            align-items: center;
        }
        .admin-top-right .btn {
            padding: 0.4rem 0.8rem;
            font-size: 0.9rem;
        }
        .admin-top-right .btn-logout {
            background-color: var(--link-active);
            border-color: var(--link-active);
            color: #fff;
        }
        .admin-top-right .btn-logout:hover,
        .admin-top-right .btn-logout:focus {
            background-color: rgba(255, 255, 255, 0.2);
            border-color: rgba(255, 255, 255, 0.3);
            color: #fff;
        }

        /* Admin list actions: always show hover colors */
        .btn-always-hover-edit,
        .btn-always-hover-edit:hover,
        .btn-always-hover-edit:focus {
            color: #fff !important;
            background-color: #6c757d !important;
            border-color: #6c757d !important;
        }
        .btn-always-hover-password,
        .btn-always-hover-password:hover,
        .btn-always-hover-password:focus {
            color: #212529 !important;
            background-color: #ffc107 !important;
            border-color: #ffc107 !important;
        }
        .btn-always-hover-delete,
        .btn-always-hover-delete:hover,
        .btn-always-hover-delete:focus {
            color: #fff !important;
            background-color: #dc3545 !important;
            border-color: #dc3545 !important;
        }
    </style>
</head>
<body>

{% include "includes/theme_toggle_button.html" %}

<div class="admin-top-right">
    <a class="btn btn-outline-light" href="{% url 'login' %}" target="_blank">View Site</a>
    <form action="{% url 'logout' %}" method="post" class="m-0">
        {% csrf_token %}
        <button class="btn btn-logout" type="submit">LOGOUT</button>
    </form>
</div>

<div class="sidebar">
    <h3 class="text-white mb-4">EduTrack Admin</h3>
    <nav class="nav flex-column">
        <a class="nav-link{% if request.resolver_match.url_name == 'admin_dashboard' %} active{% endif %}" href="{% url 'admin_dashboard' %}">Dashboard</a>
        <a class="nav-link{% if request.resolver_match.url_name == 'admin_user_list' %} active{% endif %}" href="{% url 'admin_user_list' %}">Users</a>
        <a class="nav-link{% if request.resolver_match.url_name == 'admin_student_list' %} active{% endif %}" href="{% url 'admin_student_list' %}">Students</a>
        <a class="nav-link{% if request.resolver_match.url_name == 'admin_lecturer_list' %} active{% endif %}" href="{% url 'admin_lecturer_list' %}">Lecturers</a>
        <a class="nav-link{% if request.resolver_match.url_name == 'admin_module_list' %} active{% endif %}" href="{% url 'admin_module_list' %}">Modules</a>
        <a class="nav-link{% if request.resolver_match.url_name == 'admin_program_list' %} active{% endif %}" href="{% url 'admin_program_list' %}">Programs</a>
        <a class="nav-link{% if request.resolver_match.url_name == 'admin_course_list' %} active{% endif %}" href="{% url 'admin_course_list' %}">Courses</a>
        <a class="nav-link{% if request.resolver_match.url_name == 'admin_enrollment_list' %} active{% endif %}" href="{% url 'admin_enrollment_list' %}">Enrollments</a>
        <a class="nav-link{% if request.resolver_match.url_name == 'admin_classsession_list' %} active{% endif %}" href="{% url 'admin_classsession_list' %}">Class Sessions</a>
        <a class="nav-link{% if request.resolver_match.url_name == 'admin_attendance_list' %} active{% endif %}" href="{% url 'admin_attendance_list' %}">Attendance</a>
        <a class="nav-link{% if request.resolver_match.url_name == 'admin_faceencoding_list' %} active{% endif %}" href="{% url 'admin_faceencoding_list' %}">Face Encodings</a>
        <a class="nav-link{% if request.resolver_match.url_name == 'admin_group_list' %} active{% endif %}" href="{% url 'admin_group_list' %}">Groups</a>
        <a class="nav-link{% if request.resolver_match.url_name == 'admin_permission_list' %} active{% endif %}" href="{% url 'admin_permission_list' %}">Permissions</a>
    </nav>

    <form action="{% url 'logout' %}" method="post" class="mt-2">
        {% csrf_token %}
        <button class="btn btn-danger w-100" type="submit">Logout</button>
    </form>
</div>

<div class="main-content">
    {% if messages %}
        {% for message in messages %}
            <div class="alert alert-{{ message.tags }}" role="alert">{{ message }}</div>
        {% endfor %}
    {% endif %}

    {% block content %}{% endblock %}
</div>

</body>
</html>
