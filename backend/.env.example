# Copy this file to .env and update values for your environment.

# === PRODUCTION SETTINGS ===
# For Railway: Set these in Railway dashboard → Variables

# Django
DJANGO_SECRET_KEY=replace-with-a-secure-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=your-railway-domain.up.railway.app,localhost

# === DATABASE (Neon) ===
# Get DATABASE_URL from Neon dashboard:
# Format: postgresql://user:password@hostname/dbname?sslmode=require
DATABASE_URL=postgresql://neondb_owner:npg_0DFnZraguN8y@ep-falling-sound-am1o4sdc-pooler.c-5.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# === FRONTEND DOMAIN ===
# Set to your Railway backend and Vercel frontend domains for CORS and CSRF
# Include Railway for same-origin form logins, and Vercel for cross-origin API calls
CORS_ALLOWED_ORIGINS=https://your-railway-domain.up.railway.app,https://your-site.vercel.app
CSRF_TRUSTED_ORIGINS=https://your-railway-domain.up.railway.app,https://your-site.vercel.app

# === OPTIONAL: EMAIL ===
# For password resets and notifications
#EMAIL_HOST=smtp.gmail.com
#EMAIL_PORT=587
#EMAIL_USE_TLS=True
#EMAIL_HOST_USER=you@example.com
#EMAIL_HOST_PASSWORD=your-app-password

# === OPTIONAL: SECURITY (Production) ===
